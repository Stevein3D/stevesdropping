# Neon PostgreSQL — get both from your Neon project dashboard
# Connection > Connection string (pooled) → DATABASE_URL
# Connection > Connection string (direct) → DIRECT_URL
DATABASE_URL="postgresql://username:password@ep-xxxx.us-east-1.aws.neon.tech/stevesdropping?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://username:password@ep-xxxx.us-east-1.aws.neon.tech/stevesdropping?sslmode=require"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ImageKit — get from imagekit.io > Developer Options
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/youraccountid/"
IMAGEKIT_PUBLIC_KEY="your_public_key"
IMAGEKIT_PRIVATE_KEY="your_private_key"

# Admin
ADMIN_PASSWORD="your_admin_password"
